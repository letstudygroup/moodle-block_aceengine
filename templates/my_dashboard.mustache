{{!
    @template block_aceengine/my_dashboard

    ACE Dashboard block for the My page (site dashboard).

    Shows a summary of the user's ACE progress across all enrolled courses.

    Context variables required for this template:
    * hascourses - Boolean: whether the user has ACE-enabled courses
    * totalxp - Total XP across all courses
    * highestlevel - Highest level achieved
    * avgengagement - Average engagement score
    * avgmastery - Average mastery score
    * totalactivequests - Total active quests across all courses
    * totalcompleted - Total completed quests across all courses
    * coursecount - Number of ACE-enabled courses
    * courses - Array of course data objects
        * courseid - Course ID
        * coursename - Course full name
        * courseurl - Course URL
        * dashboardurl - ACE dashboard URL for the course
        * xp - XP in this course
        * level - Level in this course
        * engagement - Engagement score
        * mastery - Mastery score
        * activequests - Number of active quests
        * completed - Number of completed quests
        * hasactivequests - Whether there are active quests

    Example context (json):
    {
        "hascourses": true,
        "totalxp": 1200,
        "highestlevel": 5,
        "avgengagement": 72,
        "avgmastery": 65,
        "totalactivequests": 4,
        "totalcompleted": 18,
        "coursecount": 3,
        "courses": [
            {
                "courseid": 5,
                "coursename": "Business Strategy",
                "courseurl": "/course/view.php?id=5",
                "dashboardurl": "/local/aceengine/index.php?courseid=5",
                "xp": 450,
                "level": 3,
                "engagement": 75,
                "mastery": 62,
                "activequests": 2,
                "completed": 8,
                "hasactivequests": true
            }
        ]
    }
}}
<div class="block-ace-my-dashboard">

    {{#hascourses}}
        {{! Summary stats }}
        <div class="d-flex flex-wrap justify-content-between mb-3">
            <div class="text-center px-2 mb-1">
                <div class="fw-bold text-warning ace-stat-value">{{totalxp}}</div>
                <small class="text-muted">XP</small>
            </div>
            <div class="text-center px-2 mb-1">
                <div class="fw-bold text-info ace-stat-value">Lv.{{highestlevel}}</div>
                <small class="text-muted">{{#str}}level, local_aceengine{{/str}}</small>
            </div>
            <div class="text-center px-2 mb-1">
                <div class="fw-bold text-primary ace-stat-value">{{avgengagement}}%</div>
                <small class="text-muted">{{#str}}engagementscore, local_aceengine{{/str}}</small>
            </div>
            <div class="text-center px-2 mb-1">
                <div class="fw-bold text-success ace-stat-value">{{avgmastery}}%</div>
                <small class="text-muted">{{#str}}masteryscore, local_aceengine{{/str}}</small>
            </div>
        </div>

        {{! Active quests summary }}
        {{#totalactivequests}}
        <div class="alert alert-warning py-2 px-3 mb-3 small">
            <i class="fa fa-bolt me-1"></i>
            {{#str}}activequests, local_aceengine{{/str}}: <strong>{{totalactivequests}}</strong>
            &middot;
            {{#str}}completedquests, local_aceengine{{/str}}: <strong>{{totalcompleted}}</strong>
        </div>
        {{/totalactivequests}}
        {{^totalactivequests}}
        <div class="text-muted small mb-3">
            <i class="fa fa-check-circle me-1 text-success"></i>
            {{#str}}completedquests, local_aceengine{{/str}}: <strong>{{totalcompleted}}</strong>
        </div>
        {{/totalactivequests}}

        {{! Course list }}
        {{#courses}}
        <div class="border rounded p-2 mb-2">
            <div class="d-flex align-items-center justify-content-between mb-1">
                <a href="{{dashboardurl}}" class="fw-bold text-truncate small" title="{{coursename}}">
                    {{coursename}}
                </a>
                <span class="badge bg-info ms-1">Lv.{{level}}</span>
            </div>
            <div class="d-flex justify-content-between small text-muted">
                <span><i class="fa fa-star text-warning me-1"></i>{{xp}} XP</span>
                <span><i class="fa fa-line-chart text-primary me-1"></i>{{engagement}}%</span>
                <span><i class="fa fa-graduation-cap text-success me-1"></i>{{mastery}}%</span>
                {{#hasactivequests}}
                <span><i class="fa fa-bolt text-warning me-1"></i>{{activequests}}</span>
                {{/hasactivequests}}
            </div>
        </div>
        {{/courses}}
    {{/hascourses}}

    {{^hascourses}}
        <p class="text-muted text-center small mb-0">
            {{#str}}noactivequests, local_aceengine{{/str}}
        </p>
    {{/hascourses}}

</div>
